<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FuseBeads.ViewModels"
             xmlns:helpers="clr-namespace:FuseBeads.Helpers"
             x:Class="FuseBeads.InstructionPage"
             x:DataType="vm:InstructionViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto" Padding="16">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Rows}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:InstructionRowViewModel">
                    <VerticalStackLayout Padding="0,4">
                        <Label FontSize="14" FontAttributes="Bold" Margin="0,4,0,2">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Reihe " />
                                    <Span Text="{Binding RowNumber}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <FlexLayout BindableLayout.ItemsSource="{Binding Cells}"
                                    Wrap="Wrap"
                                    Direction="Row"
                                    AlignItems="Center">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:BeadCellViewModel">
                                    <BoxView Color="{Binding DisplayColor}"
                                             WidthRequest="18" HeightRequest="18"
                                             CornerRadius="9"
                                             Margin="1" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1"
                Text="{helpers:Localize Back}"
                Command="{Binding GoBackCommand}"
                Margin="0,8,0,0" />
    </Grid>
</ContentPage>
