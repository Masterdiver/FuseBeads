<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FuseBeads.ViewModels"
             xmlns:helpers="clr-namespace:FuseBeads.Helpers"
             x:Class="FuseBeads.MainPage"
             x:DataType="vm:MainViewModel"
             Shell.NavBarIsVisible="False"
             Title="{helpers:Localize PageTitle}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="12">

        <!-- Header / Controls -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto,Auto">

            <!-- Title + Status (always visible) -->
            <VerticalStackLayout Grid.Row="0">
                <Label Text="{helpers:Localize AppTitle}"
                       FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="{Binding StatusText}"
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
            </VerticalStackLayout>

            <!-- Action buttons + Toggle (always visible) -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="8" Padding="0,2">
                <Button Text="{helpers:Localize PickImage}"
                        Command="{Binding PickImageCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Grid.Column="0"
                        FontSize="12" Padding="10,6" />
                <Button Text="{helpers:Localize Regenerate}"
                        Command="{Binding RegeneratePatternCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Grid.Column="1"
                        FontSize="12" Padding="10,6" />
                <!-- Column 2: * spacer -->
                <Label Text="{helpers:Localize Width}" VerticalOptions="Center" Grid.Column="3" FontSize="13" />
                <Entry Text="{Binding GridWidth}" Keyboard="Numeric" WidthRequest="55" Grid.Column="4" />
                <Button Text="{Binding ControlsPanelToggleIcon}"
                        Command="{Binding ToggleControlsPanelCommand}"
                        Grid.Column="5"
                        FontSize="14" Padding="8,6"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Collapsible controls -->
            <VerticalStackLayout Grid.Row="2"
                                 Spacing="6"
                                 IsVisible="{Binding IsControlsPanelExpanded}">

            <!-- Row 2: Palette + Max Colors -->
            <Grid ColumnDefinitions="Auto,*,Auto,70" ColumnSpacing="8" Padding="0,2">
                <Label Text="{helpers:Localize Palette}" VerticalOptions="Center" Grid.Column="0" FontSize="13" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding PaletteTypes}"
                        SelectedItem="{Binding SelectedPaletteType}" />
                <Label Text="{helpers:Localize MaxColors}" VerticalOptions="Center" Grid.Column="2" FontSize="13" />
                <Entry Text="{Binding MaxColors}" Keyboard="Numeric" WidthRequest="55" Grid.Column="3" />
            </Grid>

            <!-- Row 3: Image Adjustments -->
            <Border Padding="4" StrokeShape="RoundRectangle 6">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{helpers:Localize ImageAdjustments}" FontAttributes="Bold" FontSize="12" />
                    <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="2">
                        <Label Text="{helpers:Localize Brightness}" Grid.Row="0" Grid.Column="0" VerticalOptions="Center" FontSize="11" />
                        <Slider Grid.Row="0" Grid.Column="1" Minimum="-1" Maximum="1"
                                Value="{Binding Brightness}" />
                        <Label Text="{helpers:Localize Contrast}" Grid.Row="1" Grid.Column="0" VerticalOptions="Center" FontSize="11" />
                        <Slider Grid.Row="1" Grid.Column="1" Minimum="-1" Maximum="1"
                                Value="{Binding Contrast}" />
                        <Label Text="{helpers:Localize Saturation}" Grid.Row="2" Grid.Column="0" VerticalOptions="Center" FontSize="11" />
                        <Slider Grid.Row="2" Grid.Column="1" Minimum="-1" Maximum="1"
                                Value="{Binding Saturation}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Row 4: Options (Board Grid + Dithering) -->
            <Grid ColumnDefinitions="*,Auto,70,Auto,70" ColumnSpacing="6" Padding="0,2">
                <HorizontalStackLayout Grid.Column="0" Spacing="2">
                    <CheckBox IsChecked="{Binding EnableDithering}" VerticalOptions="Center" />
                    <Label Text="{helpers:Localize Dithering}" VerticalOptions="Center" FontSize="12" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="2">
                    <CheckBox IsChecked="{Binding ShowBoardGrid}" VerticalOptions="Center" />
                    <Label Text="{helpers:Localize BoardGrid}" VerticalOptions="Center" FontSize="12" />
                </HorizontalStackLayout>

                <Entry Grid.Column="2" Text="{Binding BoardWidth}" Keyboard="Numeric"
                       Placeholder="B" IsEnabled="{Binding ShowBoardGrid}" />
                <Label Grid.Column="3" Text="×" VerticalOptions="Center" />
                <Entry Grid.Column="4" Text="{Binding BoardHeight}" Keyboard="Numeric"
                       Placeholder="H" IsEnabled="{Binding ShowBoardGrid}" />
            </Grid>

            </VerticalStackLayout>
        </Grid>

        <!-- Loading indicator (always visible, outside collapsible panel) -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           HeightRequest="20"
                           VerticalOptions="End" HorizontalOptions="Center"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

        <!-- Main Content -->
        <ScrollView Grid.Row="1" Padding="0,8,0,0">
            <VerticalStackLayout Spacing="16">

                <VerticalStackLayout Spacing="16"
                                     IsVisible="{Binding HasPattern}">

                    <!-- Original Image -->
                    <Border Padding="8"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{helpers:Localize OriginalImage}" FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Image Source="{Binding OriginalImageSource}"
                                   Aspect="AspectFit" MaximumHeightRequest="400" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Pattern Image with zoom support -->
                    <Border Padding="8"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{helpers:Localize BeadPattern}" FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <ScrollView Orientation="Both"
                                        MaximumHeightRequest="600"
                                        HorizontalScrollBarVisibility="Always"
                                        VerticalScrollBarVisibility="Always">
                                <Image x:Name="PatternImage"
                                       Source="{Binding PatternImageSource}"
                                       Aspect="Fill">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPatternTapped" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </ScrollView>
                            <!-- Zoom controls -->
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Button Text="➖" WidthRequest="44" HeightRequest="44"
                                        Clicked="OnZoomOut" Padding="0" FontSize="18" />
                                <Label x:Name="ZoomLabel" Text="100%"
                                       VerticalOptions="Center" FontSize="14" />
                                <Button Text="➕" WidthRequest="44" HeightRequest="44"
                                        Clicked="OnZoomIn" Padding="0" FontSize="18" />
                                <Button Text="↺" WidthRequest="44" HeightRequest="44"
                                        Clicked="OnZoomReset" Padding="0" FontSize="18" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Stats -->
                <Border Padding="12" StrokeShape="RoundRectangle 8"
                        IsVisible="{Binding HasPattern}"
                        Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                    <HorizontalStackLayout Spacing="24" HorizontalOptions="Center">
                        <VerticalStackLayout>
                            <Label Text="{helpers:Localize TotalBeads}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                            <Label Text="{Binding TotalBeads}" FontSize="20" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="{helpers:Localize CheckedBeads}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                            <Label Text="{Binding CheckedBeads}" FontSize="20" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="{helpers:Localize Colors}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                            <Label Text="{Binding TotalColors}" FontSize="20" FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="{helpers:Localize Grid}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                            <Label FontSize="20" FontAttributes="Bold">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding GridWidth}" />
                                        <Span Text=" × " />
                                        <Span Text="{Binding GridHeight}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- Color Legend -->
                <Border Padding="12" StrokeShape="RoundRectangle 8"
                        IsVisible="{Binding HasPattern}"
                        Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{helpers:Localize ColorList}" FontSize="18"
                               FontAttributes="Bold" />
                        <Label Text="{helpers:Localize SortedByCount}"
                               FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

                        <Grid ColumnDefinitions="40,*,80,60" Padding="0,4">
                            <Label Text="" Grid.Column="0" FontAttributes="Bold" />
                            <Label Text="{helpers:Localize Color}" Grid.Column="1" FontAttributes="Bold" />
                            <Label Text="{helpers:Localize Count}" Grid.Column="2" FontAttributes="Bold" />
                            <Label Text="%" Grid.Column="3" FontAttributes="Bold" />
                        </Grid>

                        <CollectionView ItemsSource="{Binding ColorInfos}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ColorInfoViewModel">
                                    <Grid ColumnDefinitions="40,*,80,60"
                                          Padding="0,3" RowDefinitions="Auto">
                                        <BoxView Grid.Column="0"
                                                 Color="{Binding DisplayColor}"
                                                 WidthRequest="28" HeightRequest="28"
                                                 CornerRadius="14"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding ColorName}" FontSize="14" />
                                            <Label Text="{Binding HexCode}" FontSize="10" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding Count}"
                                               FontSize="14" VerticalOptions="Center" />
                                        <Label Grid.Column="3"
                                               Text="{Binding Percentage, StringFormat='{0:F1}%'}"
                                               FontSize="14" VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Buttons -->
        <ScrollView Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <HorizontalStackLayout Spacing="8">
                <Button Text="{helpers:Localize Instructions}"
                        Command="{Binding ShowInstructionsCommand}"
                        FontSize="12" Padding="10,8" />
                <Button Text="{helpers:Localize Print}"
                        Command="{Binding PrintCommand}"
                        FontSize="12" Padding="10,8" />
                <Button Text="{helpers:Localize ExportPdf}"
                        Command="{Binding ExportPdfCommand}"
                        FontSize="12" Padding="10,8" />
                <Button Text="{helpers:Localize Save}"
                        Command="{Binding SavePatternCommand}"
                        FontSize="12" Padding="10,8" />
                <Button Text="{helpers:Localize Load}"
                        Command="{Binding LoadPatternCommand}"
                        FontSize="12" Padding="10,8" />
                <Button Text="{helpers:Localize ShoppingList}"
                        Command="{Binding ShareShoppingListCommand}"
                        FontSize="12" Padding="10,8" />
                <Button Text="{helpers:Localize ResetProgress}"
                        Command="{Binding ResetProgressCommand}"
                        FontSize="12" Padding="10,8" />
            </HorizontalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
